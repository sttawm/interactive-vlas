molmo/

# Machine-specific paths written by each instance's setup.sh
**/.openpi_env

# Rollout artifacts: keep instructions.txt + metadata.json, drop heavy media
**/runs/**/*.mp4
**/runs/**/*.npy
**/runs/**/*.npz
